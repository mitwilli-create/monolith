# MONOLITH configuration. Copy to .env and fill in.

# Anthropic API key: powers URL → product extraction only.
# Without it, everything works except one-tap URL extraction (manual entry remains).
ANTHROPIC_API_KEY=

# Extraction model. Default: claude-opus-4-8.
# MONOLITH_MODEL=claude-opus-4-8

# HTTP port. Default: 4600.
# MONOLITH_PORT=4600

# Bind address. Default 127.0.0.1 (loopback only). A non-loopback bind
# WITHOUT real Clerk auth refuses to start — a missing secret can never
# silently expose the unauthenticated API, and there is no override. A
# hosted multi-user deploy (Clerk keys set) binds 0.0.0.0 behind the
# platform edge. For phone use against a local install, keep the loopback
# bind and reach it through an authenticated tunnel (e.g. Tailscale).
# MONOLITH_BIND=127.0.0.1

# ---------- multi-user hosting (Sprint B) ----------
# Both Clerk keys set = multi-user mode: every /api request requires a
# signed-in Clerk session and each user's data lives in its own directory
# under data/users/. Leave both empty for single-user local mode (the
# default; identical behavior to before Sprint B).
# Create an application at dashboard.clerk.com → API keys.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Comma-separated origins Clerk should accept sessions for (CSRF hardening),
# e.g. https://monolith.example.com
# CLERK_AUTHORIZED_PARTIES=

# Where user data lives. Default: ./data. A hosted deploy points this at a
# persistent volume mount.
# MONOLITH_DATA_DIR=/data

# Per-user daily ceiling on LLM-backed calls in multi-user mode (protects
# the host's Anthropic bill from a runaway beta account). Default: 60.
# MONOLITH_LLM_DAILY_CAP=60

# Dev only: stand-in auth for exercising the multi-user surface without a
# Clerk account. Refused if real Clerk keys are set. Never in production.
# MONOLITH_FAKE_AUTH=1

# Invisible-in ingestion: order-confirmation emails → proposed vault entries.
# Create an OAuth client (type: Web application) at
# console.cloud.google.com/apis/credentials with the Gmail API enabled,
# authorized redirect URI http://localhost:4600/api/ingest/oauth/callback,
# then fill these in. Scope requested is gmail.readonly; tokens live in
# data/ (gitignored). Leave empty to keep the feature off.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Override only if the app runs on a different host/port than the registered URI.
# GOOGLE_REDIRECT_URI=http://localhost:4600/api/ingest/oauth/callback
